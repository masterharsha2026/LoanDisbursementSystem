    {
      "name": "Disbursement",
      "item": [
        {
          "name": "Get All Disbursements",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/disbursement",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "disbursement"
              ]
            }
          }
        },
        {
          "name": "Get Disbursement By ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/disbursement/{{disbursementId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "disbursement",
                "{{disbursementId}}"
              ]
            }
          }
        },
        {
          "name": "Disburse Loan",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const listReq = {",
                  "    url: pm.collectionVariables.get('baseUrl') + '/api/disbursement',",
                  "    method: 'GET'",
                  "  };",
                  "  pm.sendRequest(listReq, function (err, res) {",
                  "    if (!err && res.code === 200) {",
                  "      const arr = res.json();",
                  "      if (Array.isArray(arr) && arr.length > 0) {",
                  "        pm.collectionVariables.set('disbursementId', arr[arr.length - 1].id);",
                  "      }",
                  "    }",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"loanId\": {{loanId}},\n  \"amount\": 10000.00,\n  \"remarks\": \"First disbursement\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/disbursement",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "disbursement"
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5148"
    },
    {
      "key": "loanId",
      "value": "1"
    },
    {
      "key": "disbursementId",
      "value": "1"
    }
  ]
}
